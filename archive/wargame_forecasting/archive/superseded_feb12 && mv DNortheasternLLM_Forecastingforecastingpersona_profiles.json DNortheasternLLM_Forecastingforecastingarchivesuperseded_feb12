        assert "YOUR FORECASTING TASK" not in data, "Data should not contain instructions!"
        assert "OUTPUT FORMAT" not in data, "Data should not contain output format!"

        # Verify JSON braces render correctly
        assert '{{' not in instructions, "Double braces in instructions - f-string escaping error!"
        assert '{' in instructions, "JSON example braces missing!"

        # Verify Tethys sees Novaris actions, Novaris does not
        if faction == 'tethys':
            assert 'NOVARIS ACTIONS THIS PERIOD' in data, "Tethys should see Novaris actions!"
        else:
            assert 'NOVARIS ACTIONS THIS PERIOD' not in data, "Novaris should NOT see own actions!"

        print(f"\n  Target actions: {actions}")
        print(f"\n  Instructions preview (first 300 chars):")
        print(f"  {instructions[:300]}...")

    print(f"\n{'='*60}")
    print("[OK] 4-part section split working correctly!")
    print("[OK] Instructions separated from data!")
    print("[OK] JSON format renders correctly!")
    print("[OK] Action visibility correct (Tethys sees Novaris, Novaris does not)!")
    print("[OK] All target actions present in instructions!")
