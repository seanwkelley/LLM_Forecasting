        print(f"\n{'='*60}")
        print(f"FACTION: {faction.upper()}")
        print(f"{'='*60}")

        scenario, history, data, instructions = get_action_prompt_sections(
            faction=faction,
            period=1,
            state_before=test_state,
            events=get_events(1),
            novaris_actions=['military_buildup', 'naval_deployment']
        )

        print(f"\nSection lengths:")
        print(f"  Initial scenario: {len(scenario)} chars")
        print(f"  History: {len(history)} chars")
        print(f"  Current period data: {len(data)} chars")
        print(f"  Instructions: {len(instructions)} chars")

        # Verify instructions contain all 5 target actions
        actions = get_target_actions(faction)
        for action in actions:
            assert action in instructions, f"Instructions missing action: {action}!"

